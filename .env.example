# ========================================
# OBSERVATORIO V&M - CONFIGURACIÓN DE ENTORNO
# ========================================
# Copia este archivo a .env y configura los valores según tu entorno

# ========================================
# POSTGRESQL DATABASE CONFIGURATION
# ========================================
# Usuario de PostgreSQL
POSTGRES_USER=postgres

# Contraseña de PostgreSQL
# IMPORTANTE: Genera una contraseña segura, NO uses "vm_admin123" en producción
# Puedes generar una con: openssl rand -base64 16
POSTGRES_PASSWORD=tu_contraseña_segura_aqui

# Nombre de la base de datos
POSTGRES_DB=observatorio_vm

# ========================================
# DATABASE URL (Construida automáticamente)
# ========================================
# URL de conexión a PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/base_datos
# - Docker: usa "db" como host
# - Local (Fuera de Docker): usa "localhost"
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ========================================
# REDIS CONFIGURATION
# ========================================
# URL de conexión a Redis (caché para el scraper)
# Formato: redis://host:puerto/base_datos
REDIS_URL=redis://redis:6379/0

# ========================================
# JWT SECURITY - GENERACIÓN DE CLAVES
# ========================================
# SECRET_KEY para firmar tokens JWT
# IMPORTANTE: Debe ser una cadena aleatoria segura en producción
# 
# Para generar una clave segura, ejecuta en la terminal:
# $ openssl rand -hex 32
#
# Ejemplo de salida:
# 4f92d837c1a5b6e0f2d4c3b1a0e9f8d7c6b5a4938271605b4a3c2d1e0f9a8b7c
#
# Copia la salida aquí:
JWT_SECRET_KEY=reemplazar_con_una_clave_de_64_caracteres_en_produccion

# ========================================
# ADMIN USER INITIALIZATION
# ========================================
# Contraseña para el usuario administrador inicial
# IMPORTANTE: 
# - Usa una contraseña segura (mínimo 12 caracteres)
# - Cámbiala en la primera sesión de producción
# - Nunca la dejes como "admin123"
INITIAL_ADMIN_PASSWORD=reemplazar_con_una_contraseña_segura

# ========================================
# CORS CONFIGURATION (Desarrollo)
# ========================================
# Orígenes permitidos para CORS (separados por comas)
# Para desarrollo local:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Para producción, reemplazar con:
# CORS_ORIGINS=https://tudominio.com,https://www.tudominio.com

# ========================================
# ENVIRONMENT
# ========================================
# development (con debug y reload)
# staging (testing previo a producción)
# production (sin debug, logs optimizados)
ENVIRONMENT=development

# ========================================
# RECOMENDACIONES DE SEGURIDAD
# ========================================
# 1. Nunca comitees este archivo con secretos reales a Git
# 2. Usa .env.local para desarrollo local y excluye de Git
# 3. En producción, establece variables en el servidor/CI-CD
# 4. Rota secretos regularmente
# 5. Usa un secrets manager (AWS Secrets, HashiCorp Vault, etc.)
# 6. Mantén backups de .env.example pero NUNCA de .env

# ========================================
# INSTRUCCIONES PARA PRODUCCIÓN
# ========================================
# 1. Generar contraseña segura:
#    $ openssl rand -base64 16
#
# 2. Generar JWT_SECRET_KEY:
#    $ openssl rand -hex 32
#
# 3. Enviroment en CI/CD (GitHub Actions, GitLab CI, etc.):
#    - POSTGRES_PASSWORD: Tu contraseña segura
#    - INITIAL_ADMIN_PASSWORD: Tu contraseña de admin
#    - JWT_SECRET_KEY: Tu clave JWT aleatoria
#    - CORS_ORIGINS: Tu dominio de producción
#    - ENVIRONMENT: production
#
# 4. Verificar que las variables se cargan correctamente:
#    $ docker exec vm_api printenv | grep -E "POSTGRES|JWT|ADMIN|CORS"

